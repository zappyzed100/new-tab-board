{
  "manifest_version": 3,
  "name": "New Tab Board",
  "version": "0.1.0",
  "description": "新しいタブを個人用ダッシュボードに置き換える拡張機能",
  "key": "",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": { "128": "icon128.png" },
  "permissions": [
    "storage",
    "identity",
    "alarms",
    "notifications",
    "offscreen",
    "nativeMessaging"
  ],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "oauth2": {
    "client_id": "872015431238-8ul2vrsn7crorkdqsh1s6f47hffejdnb.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/calendar.readonly"
    ]
  }
}
